// 防止头文件重复包含
#pragma once

#include <QtTypes>
#include <QCoreApplication>
#include <QDateTime>
#include <QHash>
#include <QVariant>

#include "base/pathfwd.h"

class QByteArray;
class QHostAddress;
class QString;

// 数据字段描述符的前向声明（内部结构）
struct DataFieldDescriptor;

// IP地理位置数据库类：封装MMDB格式数据库的加载、解析和查询
class GeoIPDatabase
{
    // 禁止拷贝和移动（单例或独占资源）
    Q_DISABLE_COPY_MOVE(GeoIPDatabase)
        // 声明翻译函数，支持tr()国际化
        Q_DECLARE_TR_FUNCTIONS(GeoIPDatabase)

public:
    // 从磁盘文件加载数据库，失败时error返回错误信息
    static GeoIPDatabase* load(const Path& filename, QString& error);
    // 从内存字节数组加载数据库，失败时error返回错误信息
    static GeoIPDatabase* load(const QByteArray& data, QString& error);

    // 析构函数：释放内部数据缓冲区
    ~GeoIPDatabase();

    // 获取数据库类型（如"Country"）
    QString type() const;
    // 获取数据库支持的IP版本（4或6）
    quint16 ipVersion() const;
    // 获取数据库构建时间
    QDateTime buildEpoch() const;
    // 根据IP地址查询对应的国家/地区代码（如"CN"）
    QString lookup(const QHostAddress& hostAddr) const;

private:
    // 私有构造函数：仅通过静态load方法创建，size为数据缓冲区大小
    explicit GeoIPDatabase(quint32 size);

    // 解析元数据哈希表，初始化成员变量，失败时返回false并设置error
    bool parseMetadata(const QVariantHash& metadata, QString& error);
    // 加载数据库内容（实际由load方法调用，留作扩展）
    bool loadDB(QString& error) const;
    // 从原始数据中读取元数据区块，返回QVariantHash
    QVariantHash readMetadata() const;

    // 从指定偏移量读取一个数据字段（递归解析MMDB数据类型）
    QVariant readDataField(quint32& offset) const;
    // 读取数据字段描述符（类型、大小等信息）
    bool readDataFieldDescriptor(quint32& offset, DataFieldDescriptor& out) const;
    // 将缓冲区中的大端字节序转换为主机字节序（就地修改）
    void fromBigEndian(uchar* buf, quint32 len) const;
    // 读取Map类型的值，count为键值对数量
    QVariant readMapValue(quint32& offset, quint32 count) const;
    // 读取Array类型的值，count为元素数量
    QVariant readArrayValue(quint32& offset, quint32 count) const;

    // 模板方法：读取指定长度的整型或字符串等简单值
    template <typename T> QVariant readPlainValue(quint32& offset, quint8 len) const;

    // ---------- 元数据成员 ----------
    quint16 m_ipVersion = 0;     // IP协议版本：4或6
    quint16 m_recordSize = 0;    // 记录大小（位）
    quint32 m_nodeCount = 0;     // 搜索树节点总数
    int m_nodeSize = 0;          // 每个节点的字节数
    int m_indexSize = 0;         // 索引区大小
    int m_recordBytes = 0;       // 记录字节数（每个节点包含两个记录）
    QDateTime m_buildEpoch;      // 数据库构建时间戳
    QString m_dbType;            // 数据库类型字符串

    // ---------- 查询缓存及数据 ----------
    mutable QHash<quint32, QString> m_countries;  // 缓存节点偏移量→国家代码的映射
    quint32 m_size = 0;          // 数据缓冲区总大小（字节）
    uchar* m_data = nullptr;     // 指向数据库原始数据的内存指针（由load方法分配）
};
